{
  "buildCommand": "node scripts/build_official_website.js",
  "outputDirectory": ".",
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/:prefix*/guide",
      "destination": "/:prefix*/guide.html"
    },
    {
      "source": "/:prefix*/download",
      "destination": "/:prefix*/download.html"
    }
  ]
}
