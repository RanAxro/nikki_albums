platform :osx, '10.15'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run \"flutter pub get\""
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

def inject_dylib_copy_phase
  require 'xcodeproj'

  project_path = File.join(__dir__, 'Runner.xcodeproj')
  return unless File.exist?(project_path)

  project = Xcodeproj::Project.open(project_path)
  runner_target = project.targets.find { |t| t.name == 'Runner' }
  return unless runner_target

  phase_name = 'Copy Native Dylib'

  already_exists = runner_target.build_phases.any? { |bp|
    bp.is_a?(Xcodeproj::Project::PBXShellScriptBuildPhase) && bp.name == phase_name
  }
  return if already_exists

  # 创建 Shell Script Build Phase
  phase = runner_target.new_shell_script_build_phase(phase_name)
  phase.shell_script = <<-'SCRIPT'
DYLIB_SRC="$SRCROOT/../rust/lib/macos/aarch64/libnuan5_decryption.dylib"

FRAMEWORKS_DIR="$BUILT_PRODUCTS_DIR/$FRAMEWORKS_FOLDER_PATH"
mkdir -p "$FRAMEWORKS_DIR"

if [ -f "$DYLIB_SRC" ]; then
    cp "$DYLIB_SRC" "$FRAMEWORKS_DIR/"
    echo "Copied $(basename $DYLIB_SRC) to Frameworks"
else
    echo "error: Native dylib not found at $DYLIB_SRC"
    exit 1
fi
  SCRIPT

  new_phase = runner_target.build_phases.pop
  sources_idx = runner_target.build_phases.index { |bp|
    bp.is_a?(Xcodeproj::Project::PBXSourcesBuildPhase)
  }
  insert_idx = sources_idx ? sources_idx + 1 : 1
  runner_target.build_phases.insert(insert_idx, new_phase)

  project.save
  puts "[Podfile] ✅ 已自动添加 '#{phase_name}' Build Phase 到 Runner"
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)
  end

  inject_dylib_copy_phase
end